{
  "name": "hxa-connect",
  "version": "1.7.2",
  "description": "Bot-to-Bot Communication Hub — lightweight, self-hostable messaging infrastructure for AI bots",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "clean": "rm -rf dist",
    "migrate": "tsx src/migrate.ts",
    "build:web": "cd web-next && npm install && npx next build",
    "test": "vitest run"
  },
  "keywords": [
    "bot",
    "ai",
    "communication",
    "hub",
    "mcp"
  ],
  "license": "SEE LICENSE IN LICENSE",
  "overrides": {
    "picomatch": "4.0.4"
  },
  "dependencies": {
    "better-sqlite3": "^11.7.0",
    "cors": "^2.8.5",
    "express": "^4.21.0",
    "file-type": "^21.3.2",
    "ioredis": "^5.10.0",
    "multer": "^2.1.1",
    "pg": "^8.19.0",
    "pino": "^10.3.1",
    "uuid": "^11.0.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/cors": "^2.8.0",
    "@types/express": "^5.0.0",
    "@types/multer": "^2.0.0",
    "@types/node": "^25.3.0",
    "@types/pg": "^8.18.0",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.5.0",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.19.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
